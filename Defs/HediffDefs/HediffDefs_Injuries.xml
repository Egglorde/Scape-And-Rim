<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <HediffDef ParentName="InjuryBase" Name="ScramSRP_InfeciousInjuryBase" Abstract="True">
    <hediffClass>AssemblyParasitesColonThree.Hediffs.Hediff_Injury_Infector</hediffClass>
    <tendable>true</tendable>
    <displayWound>true</displayWound>
    <labelNounPretty>{0} in the {1}</labelNounPretty>
  </HediffDef>

  <HediffDef ParentName="ScramSRP_InfeciousInjuryBase">
    <defName>ScramSRP_InfectBite</defName>
    <label>bite</label>
    <labelNoun>a infectious bite wound</labelNoun>
    <description>A infectious bite wound.</description>
    <comps>
      <li Class="HediffCompProperties_TendDuration">
        <labelTendedWell>bandaged</labelTendedWell>
        <labelTendedWellInner>sutured</labelTendedWellInner>
        <labelSolidTendedWell>set</labelSolidTendedWell>
      </li>
      <li Class="HediffCompProperties_Infecter">
        <infectionChance>0.30</infectionChance>
      </li>
      <li Class="HediffCompProperties_GetsPermanent">
        <permanentLabel>bite scar</permanentLabel>
      </li>
    </comps>
    <injuryProps>
      <painPerSeverity>0.0125</painPerSeverity>
      <averagePainPerSeverityPermanent>0.00625</averagePainPerSeverityPermanent>
      <bleedRate>0.06</bleedRate>
      <canMerge>false</canMerge>
      <destroyedLabel>Bitten off</destroyedLabel>
      <destroyedOutLabel>Bitten out</destroyedOutLabel>
    </injuryProps>
  </HediffDef>
  
  <HediffDef ParentName="InjuryBase">
    <defName>ScramSRP_NecrosisWound</defName>
    <label>tissue necrosis</label>
    <hediffClass>AssemblyParasitesColonThree.Hediffs.Hediff_Injury_Necrosis</hediffClass>
    <labelNoun>a necrotic wound</labelNoun>
    <description>A necrotic wound. Necrotic wounds never heal unless tended to, and have a high chance of infection.</description>
    <comps>
      <li Class="HediffCompProperties_TendDuration">
        <labelTendedWell>bandaged</labelTendedWell>
        <labelTendedWellInner>tended</labelTendedWellInner>
        <labelSolidTendedWell>tended</labelSolidTendedWell>
        <baseTendDurationHours>20</baseTendDurationHours>
      </li>
      <li Class="HediffCompProperties_Infecter">
        <infectionChance>0.45</infectionChance>
      </li>
    </comps>
    <injuryProps>
      <destroyedLabel>Rotted away</destroyedLabel>
      <destroyedOutLabel>Rotted out</destroyedOutLabel>
      <painPerSeverity>0.01875</painPerSeverity>
      <averagePainPerSeverityPermanent>0.00625</averagePainPerSeverityPermanent>
    </injuryProps>
  </HediffDef>

  <HediffDef ParentName="ScramSRP_InfeciousInjuryBase">
    <defName>ScramSRP_InfectInjectSim</defName>
    <label>stab</label>
    <labelNoun>a infectious stab wound</labelNoun>
    <description>A infectious stab wound, likely from an infector tendril.</description>
    <comps>
      <li Class="HediffCompProperties_TendDuration">
        <labelTendedWell>bandaged</labelTendedWell>
        <labelTendedWellInner>sutured</labelTendedWellInner>
        <labelSolidTendedWell>set</labelSolidTendedWell>
      </li>
      <li Class="HediffCompProperties_Infecter">
        <infectionChance>0.15</infectionChance>
      </li>
      <li Class="HediffCompProperties_GetsPermanent">
        <permanentLabel>stab scar</permanentLabel>
      </li>
    </comps>
    <injuryProps>
      <painPerSeverity>0.0125</painPerSeverity>
      <averagePainPerSeverityPermanent>0.00625</averagePainPerSeverityPermanent>
      <bleedRate>0.06</bleedRate>
      <canMerge>false</canMerge>
      <destroyedLabel>Cut off</destroyedLabel>
      <destroyedOutLabel>Cut out</destroyedOutLabel>
    </injuryProps>
  </HediffDef>

  <HediffDef ParentName="ScramSRP_InfeciousInjuryBase">
    <defName>ScramSRP_InfectScratch</defName>
    <label>scratch</label>
    <labelNoun>an infectious scratch</labelNoun>
    <description>An infectious scratch or tear.</description>
    <comps>
      <li Class="HediffCompProperties_TendDuration">
        <labelTendedWell>bandaged</labelTendedWell>
        <labelTendedWellInner>sutured</labelTendedWellInner>
        <labelSolidTendedWell>set</labelSolidTendedWell>
      </li>
      <li Class="HediffCompProperties_Infecter">
        <infectionChance>0.15</infectionChance>
      </li>
      <li Class="HediffCompProperties_GetsPermanent">
        <permanentLabel>scratch scar</permanentLabel>
      </li>
    </comps>
    <injuryProps>
      <painPerSeverity>0.0125</painPerSeverity>
      <averagePainPerSeverityPermanent>0.00625</averagePainPerSeverityPermanent>
      <bleedRate>0.06</bleedRate>
      <canMerge>false</canMerge>
      <destroyedLabel>Torn off</destroyedLabel>
      <destroyedOutLabel>Torn out</destroyedOutLabel>
    </injuryProps>
  </HediffDef>
</Defs>