<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <HediffDef ParentName="InfectionBase">
    <defName>ScramSRP_HediffCOTHDef</defName>
    <hediffClass>AssemblyParasitesColonThree.Hediff_COTH</hediffClass>
    <label>call of the hive</label>
    <labelNoun>coth</labelNoun>
    <description>Call of the hive is a cellular disease that slowly turns living creatures into parasites.</description>
    <tendable>false</tendable>
    <initialSeverity>0.01</initialSeverity>
    <comps>
      <li Class="HediffCompProperties_SeverityPerDay">
        <severityPerDayRange>0.925~0.463</severityPerDayRange>
      </li>
    </comps>
    <stages>
      <li>
        <label>incubating</label>
        <becomeVisible>false</becomeVisible>
      </li> 
      <li>
        <minSeverity>0.30</minSeverity>
        <label>prodromal</label>
        <becomeVisible>false</becomeVisible>
      </li>
      <li>
        <minSeverity>0.60</minSeverity>
        <label>incomplete</label>
        <becomeVisible>false</becomeVisible>
      </li>
      <li>
        <minSeverity>1</minSeverity>
        <label>hidden</label>
        <becomeVisible>false</becomeVisible>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>ScramSRP_Superheated</defName>
    <hediffClass>AssemblyParasitesColonThree.Hediffs.Hediff_Overheating</hediffClass>
    <label>internal overheat</label>
    <labelNoun>overheat</labelNoun>
    <description>The internal processes of this creature are running on overdrive, damaging internal organs.</description>
    <tendable>false</tendable>
    <initialSeverity>0.5</initialSeverity>
    <comps>
      <li Class="HediffCompProperties_SeverityPerDay">
        <severityPerDayRange>-0.7~-0.3</severityPerDayRange>
        <showHoursToRecover>true</showHoursToRecover>
      </li>
    </comps>
    <stages>
      <li>
        <painOffset>1</painOffset>
        <statFactors>
          <ComfyTemperatureMax>0.1</ComfyTemperatureMax>
        </statFactors>
      </li> 
    </stages>
  </HediffDef>
</Defs>