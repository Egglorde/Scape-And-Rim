<?xml version="1.0" encoding="utf-8" ?>
<Defs>
    <ThingDef ParentName="BaseFilth">
    <defName>ScramSRP_Filth_ResidueInfested</defName>
    <label>infested residue</label>
    <thingClass>AssemblyParasitesColonThree.Things.Filths.Filth_Parasite</thingClass>
    <tickerType>Long</tickerType>
    <useHitPoints>true</useHitPoints>
    <statBases>
      <Beauty>-30</Beauty>
      <Cleanliness>-15</Cleanliness>
      <MaxHitPoints>150</MaxHitPoints>
      <Flammability>2.0</Flammability>
    </statBases>
    <graphicData>
      <onGroundRandomRotateAngle>360</onGroundRandomRotateAngle>
      <graphicClass>Graphic_Single</graphicClass>
      <texPath>Parasite/Filth/Filth_Residue</texPath>
      <drawSize>2</drawSize>
    </graphicData>
    <filth>
        <disappearsInDays>4~6</disappearsInDays>
        <rainWashes>false</rainWashes>
        <cleaningWorkToReduceThickness>200</cleaningWorkToReduceThickness>
        <canFilthAttach>false</canFilthAttach>
        <cleaningSound>Interact_CleanFilth_Fluid</cleaningSound>
    </filth>
    </ThingDef>
    <ThingDef ParentName="BaseFilth">
      <defName>ScramSRP_Filth_AcidPuddle</defName>
      <label>acid puddle</label>
      <description>A puddle of damaging acid.</description>
      <thingClass>AssemblyParasitesColonThree.Things.Filths.Filth_Acid</thingClass>
      <useHitPoints>true</useHitPoints>
      <tickerType>Normal</tickerType>
      <statBases>
        <Beauty>-10</Beauty>
        <Cleanliness>-15</Cleanliness>
        <MaxHitPoints>150</MaxHitPoints>
        <Flammability>0.0</Flammability>
      </statBases>
      <graphicData>
        <texPath>Things/Filth/Acid</texPath>
        <graphicClass>Graphic_Random</graphicClass>
        <drawSize>2.5</drawSize>
      </graphicData>
      <filth>
        <ignoreFilthMultiplierStat>true</ignoreFilthMultiplierStat>
        <disappearsInDays>35~40</disappearsInDays>
        <rainWashes>true</rainWashes>
        <cleaningWorkToReduceThickness>70</cleaningWorkToReduceThickness>
        <canFilthAttach>true</canFilthAttach>
        <maxThickness>1</maxThickness>
        <cleaningSound>Interact_CleanFilth_Fluid</cleaningSound>
      </filth>
    </ThingDef>
</Defs>