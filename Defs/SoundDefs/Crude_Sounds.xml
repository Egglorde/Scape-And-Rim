    </SoundDef>

    <SoundDef>
        <defName>ScramSRP_HeedDeath</defName>  
        <context>MapOnly</context>   
        <subSounds>
            <li>
                <grains>
                    <li Class="AudioGrain_Clip">
                        <clipPath>Parasite/Cru/Heed/Heed_Death</clipPath> 
                    </li>
                </grains>
                <volumeRange>40~60</volumeRange>
                <pitchRange>0.8940217~1.084783</pitchRange>
