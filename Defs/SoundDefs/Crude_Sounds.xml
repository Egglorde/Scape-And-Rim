    <SoundDef>
        <defName>ScramSRP_HeedHurt</defName>  
        <context>MapOnly</context>
        <subSounds>
            <li>
                <grains>
                    <li Class="AudioGrain_Clip">
                        <clipPath>Parasite/Cru/Heed/Heed_Hurt</clipPath> 
