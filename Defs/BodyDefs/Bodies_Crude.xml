        </li>
        <li>
            <def>ParasiteLiver</def>
            <coverage>0.03</coverage>
            <customLabel>viscera</customLabel>
            <depth>Inside</depth>
        </li>
        <li>
            <def>ParasiteHeart</def>
            <coverage>0.03</coverage>
            <customLabel>hiveheart</customLabel>
            <depth>Inside</depth>
        </li>
        <li>
          <def>Leg</def>
          <customLabel>left leg</customLabel>
          <coverage>0.1</coverage>
          <height>Bottom</height>
          <groups>
            <li>Legs</li>
          </groups>
          <flipGraphic>true</flipGraphic>
            <parts>
                <li>
                    <def>ScramSRP_BoneSpike</def>
                    <customLabel>left lower bonespike</customLabel>
                    <coverage>0.06</coverage>
                    <groups>
                        <li>Legs</li>
                    </groups>
                </li>
            </parts>
        </li>
        <li>
          <def>Leg</def>
          <customLabel>right leg</customLabel>
          <coverage>0.1</coverage>
          <height>Bottom</height>
