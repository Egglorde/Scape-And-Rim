                    </groups>
                </li>
            </parts>
        </li>
        <li>
          <def>Waist</def>
          <coverage>0</coverage>
          <height>Bottom</height>
          <groups>
            <li>Waist</li>
          </groups>
        </li>
        <li>
          <def>ScramSRP_Foot</def>
          <coverage>0</coverage>
          <height>Bottom</height>
          <groups>
            <li>Waist</li>
          </groups>
        </li>
        <li>
            <def>ParasiteBrain</def>
