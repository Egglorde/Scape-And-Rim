        </li>
        <li>
          <def>Neck</def>
          <coverage>0.075</coverage>
          <height>Top</height>
          <groups>
            <li>Neck</li>
          </groups>
        </li>
        <li>
            <def>Arm</def>
            <customLabel>left limb</customLabel>
            <coverage>0.2</coverage>
            <flipGraphic>true</flipGraphic>
            <groups>
                <li>Arms</li>
            </groups>
            <parts>
                <li>
                    <def>ScramSRP_BoneSpike</def>
                    <customLabel>left bonespike</customLabel>
                    <coverage>0.06</coverage>
                    <groups>
                        <li>ScramSRP_BoneWeaponLeft</li>
                        <li>Arms</li>
                    </groups>
                </li>
            </parts>
        </li>
        <li>
            <def>Arm</def>
            <customLabel>right limb</customLabel>
            <coverage>0.2</coverage>
