<?xml version="1.0" encoding="utf-8" ?>
<Defs>
    <BodyDef>
    <defName>RuptoidBody</defName>
    <label>ruptoid</label>
    <corePart>
        <def>Body</def>
        <height>Middle</height>
        <depth>Outside</depth>
        <groups>
            <li>BodyAttackTool</li>
        </groups>
      <parts>
        <!-- Sensory tendrils for a rupter, the 4 tertiary tendrils on each side-->
        <li>
            <def>SensorTendril</def>
            <coverage>0.05</coverage>
            <customLabel>left secondary antenna</customLabel>
            <groups>
              <li>ScramSRP_TendrilA</li>
            </groups>
        </li>
        <li>
            <def>SensorTendril</def>
            <coverage>0.05</coverage>
            <customLabel>left primary antenna</customLabel>
            <groups>
              <li>ScramSRP_TendrilB</li>
            </groups>
        </li>
        <!-- Infector tendril, the large central tendril-->
        <li>
            <def>InfectorTendril</def>
            <coverage>0.05</coverage>
            <customLabel>infector tendril</customLabel>
            <groups>
                <li>InfectorAttackTool</li>
                <li>ScramSRP_TendrilC</li>
            </groups>
        </li>
        <li>
            <def>SensorTendril</def>
            <coverage>0.05</coverage>
            <customLabel>right primary antenna</customLabel>
            <groups>
              <li>ScramSRP_TendrilD</li>
            </groups>
        </li>
        <li>
            <def>SensorTendril</def>
            <coverage>0.05</coverage>
            <customLabel>right secondary antenna</customLabel>
            <groups>
              <li>ScramSRP_TendrilE</li>
            </groups>
        </li>
        <!-- Internal bits, assmued from whatever is available-->
        <li>
            <def>ParasiteBrain</def>
            <coverage>0.03</coverage>
            <customLabel>ganglia</customLabel>
            <depth>Inside</depth>
        </li>
        <li>
            <def>ScramSRP_ParasiteLiver</def>
            <coverage>0.03</coverage>
            <customLabel>viscera</customLabel>
            <depth>Inside</depth>
        </li>
        <li>
            <def>ParasiteHeart</def>
            <coverage>0.03</coverage>
            <customLabel>hiveheart</customLabel>
            <depth>Inside</depth>
        </li>
        <li>
            <def>InfectorSacLesser</def>
            <coverage>0.10</coverage>
            <customLabel>right infector sac</customLabel>
            <depth>Inside</depth>
        </li>
        <li>
            <def>InfectorSacLesser</def>
            <coverage>0.10</coverage>
            <customLabel>left infector sac</customLabel>
            <depth>Inside</depth>
        </li>
        <li>
            <def>InfectorSac</def>
            <coverage>0.20</coverage>
            <customLabel>large infector sac</customLabel>
            <depth>Inside</depth>
        </li>
        <!-- leggybits -->
        <li>
            <def>Leg</def>
            <coverage>0.05</coverage>
            <customLabel>left first leg</customLabel>
            <height>Bottom</height>
        </li>
        <li>
            <def>Leg</def>
            <coverage>0.05</coverage>
            <customLabel>left second leg</customLabel>
            <height>Bottom</height>
        </li>
        <li>
            <def>Leg</def>
            <coverage>0.05</coverage>
            <customLabel>left third leg</customLabel>
            <height>Bottom</height>
        </li>
        <li>
            <def>Leg</def>
            <coverage>0.05</coverage>
            <customLabel>right third leg</customLabel>
            <height>Bottom</height>
        </li>
      </parts>
    </corePart>
  </BodyDef>
