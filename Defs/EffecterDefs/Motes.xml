<?xml version="1.0" encoding="utf-8" ?>
<Defs>

    <ShaderTypeDef>
        <defName>ScramSRP_MoteShaderOrb</defName>
        <shaderPath>OrbShader</shaderPath>
    </ShaderTypeDef> 
     
    <FleckDef ParentName="FleckBase_Thrown">
        <defName>ScramSRP_FleckRage</defName>
        <graphicData>
          <texPath>Projectile/Rage_icon</texPath>
        </graphicData>
        <altitudeLayer>MoteOverhead</altitudeLayer>
        <fadeInTime>.1</fadeInTime>
        <solidTime>.8</solidTime>
        <fadeOutTime>.2</fadeOutTime>
        <useAttachLink>true</useAttachLink>
    </FleckDef>

    <ThingDef ParentName="MoteBase">
        <defName>ScramSRP_Mote_AdaptationIncomplete</defName>
        <thingClass>MoteAttached</thingClass>
        <altitudeLayer>Pawn</altitudeLayer>
        <mote>
            <fadeInTime>0.01</fadeInTime>
            <fadeOutTime>0.3</fadeOutTime>
            <solidTime>0.2</solidTime>
        </mote>
        <graphicData>
            <graphicClass>Graphic_PawnBodySilhouette</graphicClass>
            <color>(0.1, 1, 0.1, 1)</color>
            <shaderType>MoteGlow</shaderType>
            <texPath>Things/Mote/Transparent</texPath>
        </graphicData>
    </ThingDef>
    <ThingDef ParentName="MoteBase">
        <defName>ScramSRP_Mote_AdaptationComplete</defName>
        <thingClass>MoteAttached</thingClass>
        <altitudeLayer>Pawn</altitudeLayer>
        <mote>
            <fadeInTime>0.01</fadeInTime>
            <fadeOutTime>0.3</fadeOutTime>
            <solidTime>0.2</solidTime>
        </mote>
        <graphicData>
            <graphicClass>Graphic_PawnBodySilhouette</graphicClass>
            <color>(0.75, 0, 0.75, 1)</color>
            <shaderType>MoteGlow</shaderType>
            <texPath>Things/Mote/Transparent</texPath>
        </graphicData>
    </ThingDef>  
    <ThingDef ParentName="MoteBase">
        <defName>ScramSRP_BiomassMoteGreater</defName>
        <graphicData>
            <texPath>Projectile/BiomassFleck</texPath>
            <shaderType>Mote</shaderType>
        </graphicData>
        <altitudeLayer>MoteOverhead</altitudeLayer>
        <mote>
            <solidTime>1</solidTime>
            <fadeOutTime>0.3</fadeOutTime>
            <acceleration>(0, 0, 2)</acceleration>
        </mote>
    </ThingDef>
    <ThingDef ParentName="MoteBase">
        <defName>ScramSRP_BiomassMoteLesser</defName>
        <graphicData>
            <texPath>Projectile/BiomassFleck</texPath>
            <shaderType>Mote</shaderType>
        </graphicData>
        <altitudeLayer>MoteOverhead</altitudeLayer>
        <mote>
            <solidTime>0.7</solidTime>
            <fadeOutTime>0.1</fadeOutTime>
            <acceleration>(0, 0, 1)</acceleration>
        </mote>
    </ThingDef>
    <ThingDef ParentName="MoteBase">
        <defName>ScramSRP_BiomassMoteShare</defName>
        <graphicData>
            <texPath>Projectile/BiomassFleck</texPath>
            <shaderType>Mote</shaderType>
        </graphicData>
        <altitudeLayer>Projectile</altitudeLayer>
        <mote>
            <fadeInTime>0.2</fadeInTime>
            <solidTime>0.7</solidTime>
            <fadeOutTime>0.3</fadeOutTime>
        </mote>
    </ThingDef>
    <!-- BEAMS -->
    <ThingDef ParentName="MoteBase">
        <defName>ScramSRP_WebbingMote</defName>
        <thingClass>MoteDualAttached</thingClass>
        <altitudeLayer>Projectile</altitudeLayer>
        <mote>
          <fadeInTime>0.01</fadeInTime>
          <fadeOutTime>0.01</fadeOutTime>
          <solidTime>999999</solidTime>
          <needsMaintenance>True</needsMaintenance>
          <rotateTowardsTarget>True</rotateTowardsTarget>
          <scaleToConnectTargets>True</scaleToConnectTargets>
          <fadeOutUnmaintained>True</fadeOutUnmaintained>
        </mote>
        <drawOffscreen>true</drawOffscreen>
        <graphicData>
          <texPath>Projectile/Webbing_line</texPath>
        </graphicData>
    </ThingDef>
    <ThingDef ParentName="MoteBase">
        <defName>ScramSRP_MeatyTendrilMote</defName>
        <thingClass>MoteDualAttached</thingClass>
        <altitudeLayer>Projectile</altitudeLayer>
        <mote>
          <fadeInTime>0.3</fadeInTime>
          <fadeOutTime>0.3</fadeOutTime>
          <solidTime>999999</solidTime>
          <needsMaintenance>True</needsMaintenance>
          <rotateTowardsTarget>True</rotateTowardsTarget>
          <scaleToConnectTargets>True</scaleToConnectTargets>
          <fadeOutUnmaintained>True</fadeOutUnmaintained>
        </mote>
        <drawOffscreen>true</drawOffscreen>
        <graphicData>
          <texPath>Projectile/Umbilical</texPath>
        </graphicData>
    </ThingDef>
    <ThingDef ParentName="MoteBase">
        <defName>ScramSRP_Mote_Orb</defName>
        <thingClass>MoteAttached</thingClass>
        <altitudeLayer>MoteOverhead</altitudeLayer>
        <drawOffscreen>true</drawOffscreen>
        <mote>
            <solidTime>9999999</solidTime>
            <needsMaintenance>true</needsMaintenance>
            <scalers>
              <li>
                <scaleAmt>2</scaleAmt>
                <scaleTime>2</scaleTime>
                <axisMask>(1, 0, 1)</axisMask>
                <curve>
                    <points>
                        <li>(0,0)</li>
                        <li>(1,1)</li>
                    </points>
                </curve>
              </li>
            </scalers>
        </mote>
        <graphicData>
            <graphicClass>Graphic_Mote</graphicClass>
            <shaderType>ScramSRP_MoteShaderOrb</shaderType>
            <color>(1, 1, 1, 0.5)</color>
            <texPath>Parasite/Effects/Orb</texPath>
            <shaderParameters>
              <_SecondaryTex>/Parasite/Effects/Noises/Noise4</_SecondaryTex>
            </shaderParameters>
            <drawSize>3</drawSize>
        </graphicData>
    </ThingDef>   
</Defs>