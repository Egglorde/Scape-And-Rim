    <ToolCapacityDef>
        <defName>ScramSRP_SlamCap</defName>
        <label>slam</label>
    </ToolCapacityDef>

    <!-- Direct conversion damage defs -->
    <DamageDef Name="ScramSRP_DirectConvertDamageBase" Abstract="True">
        <workerClass>DamageWorker_AddInjury</workerClass>
        <label>assimilate</label>
        <externalViolence>true</externalViolence>
        <deathMessage>{0} has been assimilated.</deathMessage>
        <armorCategory>Sharp</armorCategory>
        <hediffSolid>Crack</hediffSolid>
    </DamageDef>

    <DamageDef Name="ScramSRP_DirectConvertDamageBite" ParentName="ScramSRP_DirectConvertDamageBase">
        <defName>ScramSRP_DirectConvertDamageBite</defName>
        <workerClass>DamageWorker_AddInjury</workerClass>
        <hediff>ScramSRP_InfectBite</hediff>
    </DamageDef>

    <DamageDef Name="ScramSRP_DirectConvertDamageStab" ParentName="ScramSRP_DirectConvertDamageBase">
        <defName>ScramSRP_DirectConvertDamageStab</defName>
        <hediff>ScramSRP_InfectInjectSim</hediff>
    </DamageDef>

    <DamageDef Name="ScramSRP_DirectConvertDamageScratch" ParentName="ScramSRP_DirectConvertDamageBase">
      <defName>ScramSRP_DirectConvertDamageScratch</defName>
      <workerClass>DamageWorker_Scratch</workerClass>
      <hediff>ScramSRP_InfectScratch</hediff>
      <harmAllLayersUntilOutside>true</harmAllLayersUntilOutside>
      <impactSoundType>Slice</impactSoundType>
      <overkillPctToDestroyPart>0~0.7</overkillPctToDestroyPart>
      <scratchSplitPercentage>0.67</scratchSplitPercentage>
    </DamageDef>

