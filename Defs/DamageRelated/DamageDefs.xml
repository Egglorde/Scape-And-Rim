    <!-- Necrosis and Vomit damage -->

    <DamageDef Name="ScramSRP_NecrosisDamage" ParentName="Flame">
        <defName>ScramSRP_NecrosisDamage</defName>
        <label>rotted</label>
        <workerClass>DamageWorker_AddInjury</workerClass>
        <deathMessage>{0} has rotted away.</deathMessage>
        <armorCategory>Sharp</armorCategory>
        <hediff>ScramSRP_NecrosisWound</hediff>
        <scaleDamageToBuildingsBasedOnFlammability>false</scaleDamageToBuildingsBasedOnFlammability>
