            <baseBodySize>2.65</baseBodySize>
            <baseHealthScale>3.8</baseHealthScale>
            <body>ScramSRP_PrimitiveArachnidaBody</body>
            <renderTree>ScramSRP_ArachnidaRenderTree</renderTree>
            <lifeStageAges>
                <li>
                    <def>InbornBaseAge</def>
                    <minAge>0</minAge>
                    <soundWounded>ScramSRP_PriLongarmsHurt</soundWounded>
                    <soundDeath>ScramSRP_PriLongarmsDeath</soundDeath>
                    <soundCall>ScramSRP_PriLongarmsCall</soundCall>
                </li>
            </lifeStageAges>
        </race>
        <statBases>
            <MoveSpeed>10</MoveSpeed>
            <ArmorRating_Blunt>0.35</ArmorRating_Blunt>
            <ArmorRating_Sharp>0.7</ArmorRating_Sharp>
        </statBases>
        <tools>
            <li>
                <label>maw</label>
                <capacities>
                    <li>ScramSRP_DirectConvertCapBite</li>
                </capacities>
                <power>20</power>
                <cooldownTime>3</cooldownTime>
                <linkedBodyPartsGroup>Teeth</linkedBodyPartsGroup>
                <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
                <chanceFactor>0.6</chanceFactor>
                <armorPenetration>0.6</armorPenetration>
            </li>
            <li>
                <label>body</label>
                <capacities>
                    <li>Blunt</li>
                </capacities>
                <power>12.13</power>
                <cooldownTime>2</cooldownTime>
                <linkedBodyPartsGroup>BodyAttackTool</linkedBodyPartsGroup>
                <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
                <chanceFactor>0.2</chanceFactor>
            </li>
            <li>
                <label>right claw</label>
                <capacities>
                    <li>ScramSRP_DirectConvertCapScratch</li>
                    <li>ScramSRP_DirectConvertCapStab</li>
                </capacities>
                <power>17.5</power>
                <cooldownTime>1</cooldownTime>
                <linkedBodyPartsGroup>FrontRightClaws</linkedBodyPartsGroup>
                <armorPenetration>0.75</armorPenetration>
            </li>
            <li>
                <label>left claw</label>
                <capacities>
                    <li>ScramSRP_DirectConvertCapScratch</li>
                    <li>ScramSRP_DirectConvertCapStab</li>
                </capacities>
                <power>17.5</power>
                <cooldownTime>1</cooldownTime>
                <linkedBodyPartsGroup>FrontLeftClaws</linkedBodyPartsGroup>
                <armorPenetration>0.75</armorPenetration>
            </li>
        </tools>
        <comps>
            <li Class="AssemblyParasitesColonThree.CompProps.CompProperties_OrbUser">
                <enemyHediffs>
                    <li>ScramSRP_Hunger</li>
                    <li>ScramSRP_Blindness</li>
                </enemyHediffs>
                <Potency>0.45</Potency>
            </li>
        </comps>
    </ThingDef>
    <PawnKindDef ParentName="ScramSRP_BasePrimitiveParasiteKind">
        <defName>ScramSRP_Pri_ArachnidaKind</defName>
