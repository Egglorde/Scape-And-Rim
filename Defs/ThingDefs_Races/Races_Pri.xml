<Defs>
    <!-- Basic primitive parasite body type -->
    <ThingDef ParentName="BaseParasite" Name="BasePrimitive" Abstract="True">
        <race>
            <leatherDef>Leather_Patch</leatherDef>
            <specificMeatDef>ScramSRP_InfectedFlesh</specificMeatDef>
        </race>
        <statBases>
            <MoveSpeed>4</MoveSpeed>
            <ArmorRating_Heat>0</ArmorRating_Heat>
            <ArmorRating_Blunt>0.222</ArmorRating_Blunt>
            <ArmorRating_Sharp>0.461</ArmorRating_Sharp>
            <ComfyTemperatureMin>-80</ComfyTemperatureMin>
            <ComfyTemperatureMax>60</ComfyTemperatureMax>
            <LeatherAmount>20</LeatherAmount>
            <PsychicSensitivity>1.5</PsychicSensitivity>
            <ToxicResistance>0.5</ToxicResistance>
            <MeleeHitChance>3</MeleeHitChance>
            <StaggerDurationFactor>0.6</StaggerDurationFactor>
        </statBases>
        <comps>
            <li Class="AssemblyParasitesColonThree.CompProps.CompProperties_EvolverParasite_Kills">
                <evolutionTarget>ScramSRP_Beckon2</evolutionTarget>
                <ReqKills>10</ReqKills>
            </li>
            <li Class="AssemblyParasitesColonThree.CompProps.CompProperties_DeathExplosionRemain">
                <remaintier>Primitive</remaintier>
                <canMakeCrux>true</canMakeCrux>
            </li>
