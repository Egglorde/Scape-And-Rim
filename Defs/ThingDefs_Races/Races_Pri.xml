                <learnChance>0.7</learnChance>
                <failChance>0.7</failChance>
                <reductionPerPoint>0.05</reductionPerPoint>
                <reductionCap>12</reductionCap>
                <maxLearnedDamageSources>5</maxLearnedDamageSources>
            </li>
        </comps>
    </ThingDef>

    <ThingDef ParentName="BasePrimitive" Name="BasePrimitiveLarge" Abstract="True">
