    <!-- Crux-->
    <ThingDef ParentName="BaseParasite">
        <defName>ScramSRP_Crux</defName>
        <label>crux</label>
        <description>Framework of a brutish, selfless creature still knitting itself together. Its rage deepens with every corpse it leaves behind. It is capable of hurling items, buildings, or living creatures at enemies. Under immense strain, its body secretes a strange boiling orange substance, and when driven to great speed, steam rises from it as though the whole frame is on the verge of catching fire.</description>
        <race>
            <baseBodySize>7</baseBodySize>
            <baseHealthScale>10</baseHealthScale>
            <body>ScramSRP_CruxBody</body>
            <renderTree>ScramSRP_SizeOnKillRenderTree</renderTree>
            <lifeStageAges>
                <li>
                    <def>InbornBaseAge</def>
                    <minAge>0</minAge>
                    <soundWounded>ScramSRP_CruxHurt</soundWounded>
                    <soundDeath>ScramSRP_CruxDeath</soundDeath>
                    <soundCall>ScramSRP_CruxCall</soundCall>
                </li>
            </lifeStageAges>
            <leatherDef>Leather_Patch</leatherDef>
            <specificMeatDef>ScramSRP_InfectedFlesh</specificMeatDef>
            <thinkTreeMain>ScramSRP_CruxThink</thinkTreeMain>
            <soundMoving>ScramSRP_PriAdaMoving</soundMoving>
        </race>
        <statBases>
            <CarryingCapacity>1000</CarryingCapacity>
            <MoveSpeed>9</MoveSpeed>
            <ArmorRating_Heat>1.5</ArmorRating_Heat>
            <ArmorRating_Blunt>0.1</ArmorRating_Blunt>
            <ArmorRating_Sharp>0.3</ArmorRating_Sharp>
            <ComfyTemperatureMin>-80</ComfyTemperatureMin>
            <ComfyTemperatureMax>120</ComfyTemperatureMax>
            <PsychicSensitivity>1.5</PsychicSensitivity>
            <ToxicResistance>0.5</ToxicResistance>
