    <ThingDef ParentName="BaseParasite" Name="BaseCarrierGround" Abstract="True">
        <statBases>
            <MoveSpeed>5.3</MoveSpeed>
        </statBases>
        <hiddenWhileUndiscovered>true</hiddenWhileUndiscovered>
        <race>
            <bloodDef>ScramSRP_Filth_ResidueInfested</bloodDef>
            <body>CarrierGroundBody</body>
            <corpseHiddenWhileUndiscovered>true</corpseHiddenWhileUndiscovered>
            <lifeStageAges>
                <li>
                    <def>InbornBaseAge</def>
                    <minAge>0</minAge>
                    <soundWounded>ScramSRP_Hurt_Carrier</soundWounded>
                    <soundDeath>ScramSRP_Death_Carrier</soundDeath>
                    <soundCall>ScramSRP_Call_Carrier</soundCall>
                </li>
            </lifeStageAges>
        </race>
        <tools>
            <li>
                <label>left leg</label>
                <labelNoLocation>leg</labelNoLocation>
                <capacities>
                    <li>Blunt</li>
                </capacities>
                <power>12.0</power>
                <cooldownTime>4</cooldownTime>
                <linkedBodyPartsGroup>LeftLeg</linkedBodyPartsGroup>
                <alwaysTreatAsWeapon>true</alwaysTreatAsWeapon>
            </li>
            <li>
                <label>right leg</label>
                <labelNoLocation>leg</labelNoLocation>
                <capacities>
                    <li>Blunt</li>
                </capacities>
                <power>12.0</power>
                <cooldownTime>4</cooldownTime>
                <linkedBodyPartsGroup>RightLeg</linkedBodyPartsGroup>
                <alwaysTreatAsWeapon>true</alwaysTreatAsWeapon>
            </li>
        </tools>
    </ThingDef>

    <ThingDef ParentName="BaseCarrierGround">
        <defName>ScramSRP_Carrier_Light_Race</defName>
        <label>light carrier</label>
        <description>Light Carriers are Small Infestation Propagators that hold other infectors.</description>
        <race>
            <baseBodySize>1.2</baseBodySize>
            <deathAction Class="AssemblyParasitesColonThree.DeathActionProperties_PopIntoParas">
                <workerClass>AssemblyParasitesColonThree.DeathActionWorker_PopIntoParas</workerClass>
                <carrierpawnkindoptions>
                    <li>Rupter</li>
                </carrierpawnkindoptions>
                <popRange>3</popRange>
                <dividePawnCount>5</dividePawnCount>
            </deathAction>
        </race>
    </ThingDef>

    <PawnKindDef ParentName="BaseParasiteKind">
