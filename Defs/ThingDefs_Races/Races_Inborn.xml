<?xml version="1.0" encoding="utf-8" ?>
<Defs>
    <!-- Abstract for Ruptoid Parasites-->
    <ThingDef ParentName="BaseParasite" Name="BaseRuptoid" Abstract="True">
        <statBases>
            <MoveSpeed>6</MoveSpeed>
        </statBases>
        <race>
            <body>RuptoidBody</body>
            <lifeStageAges>
                <li>
                    <def>InbornBaseAge</def>
                    <minAge>0</minAge>
                    <soundWounded>ScramSRP_Hurt_Inborn</soundWounded>
                    <soundDeath>ScramSRP_Death_Inborn</soundDeath>
                    <soundCall>ScramSRP_Call_Inborn</soundCall>
                </li>
            </lifeStageAges>
            <baseHealthScale>0.5</baseHealthScale>
        </race>
        <tools>
            <li>
                <label>infector tendril</label>
                <capacities>
                    <li>ScramSRP_DirectConvertCapStab</li>
                </capacities>
                <power>10</power>
                <cooldownTime>2</cooldownTime>
                <alwaysTreatAsWeapon>true</alwaysTreatAsWeapon>
                <linkedBodyPartsGroup>InfectorAttackTool</linkedBodyPartsGroup>
                <hediff>ScramSRP_HediffCOTHDef</hediff>
                <chanceFactor>1.00</chanceFactor>
            </li>
            <li>
                <label>body</label>
                <capacities>
                    <li>Blunt</li>
                </capacities>
                <power>8</power>
                <cooldownTime>2</cooldownTime>
                <linkedBodyPartsGroup>BodyAttackTool</linkedBodyPartsGroup>
                <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
                <chanceFactor>0.2</chanceFactor>
            </li>
        </tools>
    </ThingDef>
    <ThingDef ParentName="BaseRuptoid">
        <defName>Rupter</defName>
        <label>rupter</label>
        <description>Rupters are infestation propagators and swarm units, attacking at close to moderate range and guaranteed to inflict the Call of the Hive.</description>
        <race>
            <thinkTreeMain>ParasiteAmbusher</thinkTreeMain>
        </race>
        <comps>
            <li Class="AssemblyParasitesColonThree.CompProps.CompProperties_EvolverParasite_Kills">
                <evolutionTarget>ScramSRP_Mangler</evolutionTarget>
                <ReqKills>30</ReqKills>
            </li>
        </comps>
    </ThingDef>
    <ThingDef ParentName="BaseRuptoid">
        <defName>ScramSRP_ManglerRace</defName>
        <label>mangler</label>
        <description>Manglers are highly mobile, swarming melee combatants, attacking at close to moderate range and guaranteed to inflict the Call of the Hive.</description>
        <statBases>
            <MeleeDodgeChance>0.8</MeleeDodgeChance>
            <MeleeCooldownFactor>0.25</MeleeCooldownFactor>
        </statBases>
        <race>
            <thinkTreeMain>ParasiteLeaper</thinkTreeMain>
            <renderTree>ScramSRP_ManglerTendrils</renderTree>
            <baseHealthScale>0.85</baseHealthScale>
        </race>
        <comps>
            <li Class="AssemblyParasitesColonThree.CompProps.CompProperties_Adaptation">
                <learnChance>0.95</learnChance>
                <failChance>0.3</failChance>
                <reductionPerPoint>0.125</reductionPerPoint>
                <reductionCap>8</reductionCap>
                <maxLearnedDamageSources>12</maxLearnedDamageSources>
            </li>
        </comps>
    </ThingDef>
    <ThingDef ParentName="BaseParasite">
