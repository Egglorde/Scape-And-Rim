<?xml version="1.0" encoding="utf-8" ?>
<Defs>  
    <IncidentDef>
      <defName>ScramSRP_RaidParasiteScent</defName>
      <label>parasite raid</label>
      <targetTags>
        <li>Map_PlayerHome</li>
        <li>Map_TempIncident</li>
        <li>Map_Misc</li>
        <li>Map_RaidBeacon</li>
      </targetTags>
      <workerClass>AssemblyParasitesColonThree.Misc.IncidentWorker_RaidParasite</workerClass>
      <baseChance>10</baseChance>
      <category>ScramSRP_ThreatBigParasite</category>
      <pointsScaleable>true</pointsScaleable>
      <tale>Raid</tale>
      <ignoreRecentSelectionWeighting>true</ignoreRecentSelectionWeighting>
      <canOccurOnAllPlanetLayers>true</canOccurOnAllPlanetLayers>
    </IncidentDef>

    <IncidentCategoryDef>
      <defName>ScramSRP_ThreatBigParasite</defName>
      <needsParmsPoints>true</needsParmsPoints>
      <tale>MajorThreat</tale>
      <canUseAnomalyChance>false</canUseAnomalyChance>
    </IncidentCategoryDef>

    <FactionDef ParentName="FactionBase">
    <defName>ScramSRP_ParasiteFaction</defName>
    <label>parasite horde</label>
    <fixedName>Parasitic hordes</fixedName>
    <pawnSingular>parasite</pawnSingular>
    <pawnsPlural>parasites</pawnsPlural>
    <requiredCountAtGameStart>1</requiredCountAtGameStart>
    <raidCommonalityFromPointsCurve>
      <points>
        <li>(300,  0)</li>
        <li>(700,  1)</li>
        <li>(1400, 1.8)</li>
        <li>(2800, 2.2)</li>
        <li>(4000, 2.6)</li>
      </points>
    </raidCommonalityFromPointsCurve>
    <hidden>true</hidden>
    <displayInFactionSelection>false</displayInFactionSelection>
    <autoFlee>false</autoFlee>
    <canUseAvoidGrid>false</canUseAvoidGrid>
    <techLevel>Animal</techLevel>
    <raidsForbidden>false</raidsForbidden>
    <permanentEnemyToEveryoneExcept>
      <li>Insect</li>
    </permanentEnemyToEveryoneExcept>
    <hostileToFactionlessHumanlikes>true</hostileToFactionlessHumanlikes>
    <settlementTexturePath>World/WorldObjects/DefaultSettlement</settlementTexturePath>
    <allowedArrivalTemperatureRange>-100~100</allowedArrivalTemperatureRange>
    <maxConfigurableAtWorldCreation>1</maxConfigurableAtWorldCreation>
    <configurationListOrderPriority>1000</configurationListOrderPriority>
    <maxPawnCostPerTotalPointsCurve>
      <points>
        <li>(400,200)</li>
        <li>(900,300)</li>
        <li>(100000,10000)</li>
      </points>
    </maxPawnCostPerTotalPointsCurve>
    <arrivalModeWhitelist>
      <li>ScramSRP_WormArrival</li>
    </arrivalModeWhitelist>
    <backstoryFilters>
      <li>
        <categories>
          <li>Outlander</li>
        </categories>
        <commonality>0.95</commonality>
      </li>
      <li>
        <categories>
          <li>Offworld</li>
        </categories>
        <commonality>0.05</commonality>
      </li>
    </backstoryFilters>
    <pawnGroupMakers Inherit="False">
      <!-- Basic -->
      <li>
                <!-- All types-->
            <kindDef>Combat</kindDef>
            <commonality>500</commonality>
            <options>
                <Rupter>15</Rupter>
                <ScramSRP_HeedKind>1</ScramSRP_HeedKind>
                <ScramSRP_Carrier_Light>3</ScramSRP_Carrier_Light>
                <ScramSRP_Pri_ArachnidaKind>3</ScramSRP_Pri_ArachnidaKind>
                <ScramSRP_Pri_ReekerKind>3</ScramSRP_Pri_ReekerKind>
                <ScramSRP_Pri_LongArmsKind>3</ScramSRP_Pri_LongArmsKind>
                <ScramSRP_Pri_ManducaterKind>3</ScramSRP_Pri_ManducaterKind>
                <ScramSRP_Pri_YelloweyeKind>3</ScramSRP_Pri_YelloweyeKind>
                <ScramSRP_Pri_SummonerKind>3</ScramSRP_Pri_SummonerKind>
                <ScramSRP_Pri_BolsterKind>3</ScramSRP_Pri_BolsterKind>
            </options>
        </li>
      <!-- Inborn -->
      <li>
                <!-- Inborn only-->
            <kindDef>Combat</kindDef>
            <commonality>100</commonality>
            <options>
                <ScramSRP_Mangler>1</ScramSRP_Mangler>
                <Rupter>15</Rupter>
                <ScramSRP_Carrier_Light>3</ScramSRP_Carrier_Light>
            </options>
        </li>
    </pawnGroupMakers>
  </FactionDef>
</Defs>